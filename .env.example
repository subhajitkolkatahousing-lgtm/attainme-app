# Environment Variables for Vercel Deployment
# Copy this to .env.local for local development

# DATABASE_URL - Connection pooling URL (used by app at runtime)
DATABASE_URL="postgresql://username:password@ep-xxx.region.aws.neon.tech/verceldb?sslmode=require"

# DIRECT_URL - Direct connection URL (used by Prisma CLI for migrations)
DIRECT_URL="postgresql://username:password@ep-xxx.region.aws.neon.tech/verceldb?sslmode=require"
