# ============================================
# 🖥️ LOCAL DEVELOPMENT (SQLite)
# ============================================
# Uncomment these 2 lines for local dev, comment out the PostgreSQL lines below
# DATABASE_URL="file:./db/custom.db"

# ============================================
# ☁️ VERCEL PRODUCTION (PostgreSQL - Neon)
# ============================================
# Set real values in Vercel Dashboard → Settings → Environment Variables
# These are placeholders - Vercel will override them during deployment
DATABASE_URL="postgresql://placeholder:placeholder@ep-placeholder.neon.tech/verceldb?sslmode=require"
DIRECT_URL="postgresql://placeholder:placeholder@ep-placeholder.neon.tech/verceldb?sslmode=require"
